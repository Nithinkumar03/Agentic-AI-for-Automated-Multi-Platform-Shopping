# Get a key at https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# Optional model override (Groq/OpenAI-compatible naming)
# GROQ_MODEL=llama-3.3-70b-versatile

# Vision model for /api/scan-list (photo of shopping list)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# DMart Next.js dev server (npm run dev)
DMART_BASE_URL=http://127.0.0.1:3000

# Selenium
SELENIUM_HEADLESS=0
SELENIUM_IMPLICIT_WAIT=3
